{
    "include": ["NetscriptDefinitions.d.ts", "src/**/*"],
    "exclude": ["src/lib/react.ts"],
    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "module": "esnext",
        "target": "esnext",
        "moduleResolution": "node",
        "noImplicitReturns": true,
        "noImplicitThis": true,
        "esModuleInterop": true,
        "inlineSourceMap": true,
        "inlineSources": true,
        "strict": true,
        "rootDir": "src/",
        "outDir": "dist/",
        "baseUrl": "src/",
        "allowJs": true,
        "jsx": "react",

        "noImplicitAny": true, //           Strong Type Strict Checks
        "strictNullChecks": true, //        Strong Type Strict Checks
        "paths": {
            "/*": ["*"],
            "@ns": ["../NetscriptDefinitions.d.ts"],
            "@react": ["lib/react.ts"]
        }
    }
}
